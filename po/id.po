#: data/org.nicotine_plus.Nicotine.desktop.in:6 pynicotine/__init__.py:34
#: pynicotine/gtkgui/ui/dialogs/fastconfigure.ui:116
msgid "Graphical client for the Soulseek peer-to-peer network"
msgstr "Klien grafis untuk jaringan peer-to-peer Soulseek"

#: data/org.nicotine_plus.Nicotine.desktop.in:11
msgid "Soulseek;Nicotine;sharing;chat;messaging;P2P;peer-to-peer;GTK;"
msgstr "Soulseek;Nicotine;berbagi;berbincang;perpesanan,P2P;mitra ke mitra;GTK;"

#: data/org.nicotine_plus.Nicotine.appdata.xml.in:12
msgid "Browse the Soulseek network"
msgstr "Jelajahi jaringan Soulseek"

#: data/org.nicotine_plus.Nicotine.appdata.xml.in:14
msgid "Nicotine+ is a graphical client for the Soulseek peer-to-peer network."
msgstr "Nicotine+ adalah klien grafis untuk jaringan peer-to-peer Soulseek."

#: data/org.nicotine_plus.Nicotine.appdata.xml.in:17
msgid ""
"Share files, chat, and find people with similar interests. Nicotine+ is user-"
"friendly, fast, free, and open source. It provides features and refinements "
"that focus on usability, while remaining fully compatible with other "
"Soulseek clients."
msgstr ""
"Berbagi file, berbincang, dan mencari orang dengan minat yang sama . "
"Nicotine+ adalah aplikasi ramah pengguna, cepat, gratis, dan sumber terbuka. "
"Nicotine+ menyediakan fitur dan penyempurnaan berfokus pada kegunaan, "
"sembari sepenuhnya kompatibel dengan klien Soulseek lain."

